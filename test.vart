i32 name <- 9;
?{y == 3 \/ x ==3} -> {
  name <- 10;
} -> ?{y == 2 /\ x != 5} -> {
  name <- 11;
} -> {
  name <- 12;
}

?{!y} -> {
  name <-2;
}
<-@-> i32 num <- @{i32 x <- 3, i32 y <- 2} -> {
  name <- 40;
}

<-?->{i32 i <- 0; i <= 23; i++} -> {
  name++;
}

<->{i32 value <-> list} -> {
  name--;
}
